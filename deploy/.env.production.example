# MedHarness v0.5.0-edge production environment template
# Copy to .env.production and adjust before running docker compose.
# .env.production must stay gitignored and out of the Docker build context.

VERSION=0.5.0-edge
TLS_CERT_DIR=/etc/medharness/tls

CLICKHOUSE_DATABASE=medharness
CLICKHOUSE_USER=medharness
CLICKHOUSE_PASSWORD=change-me-clickhouse-password

REDIS_PASSWORD=change-me-redis-password
NEW_API_CRYPTO_SECRET=change-me-new-api-crypto-secret
