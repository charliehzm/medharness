{
  "skill": "memory-curate",
  "version": "1.1-v2.2",
  "_note": "v2.2 调优：v2.1 实测手动触发率 8% — 几乎无人调。本版改为'自动 cron + 手动备份'两路径。",
  "execution_model": "primary=cron(Mon morning); secondary=manual",
  "trigger_examples": {
    "positive_manual": [
      {"prompt": "Memory 健康分检查"},
      {"prompt": "整理 .memory/"},
      {"prompt": "$memory-curate"},
      {"prompt": "Memory 周报"}
    ],
    "auto_triggered_via": "scripts/curator/run_memory_curate.py via cron / GitHub Actions",
    "negative_should_not_trigger": [
      {"prompt": "改 .memory/ 里的一个文件", "reason": "单文件编辑用 Edit，不进 curate"}
    ]
  },
  "weekly_health_target": 0.95,
  "auto_schedule": "0 9 * * 1 (Monday 09:00 local)"
}
